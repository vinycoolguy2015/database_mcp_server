# Database connection
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=5432
DB_NAME=mydb
DB_USER=readonly_user
DB_PASSWORD=your_password
DB_TYPE=postgresql

# Access control
ALLOWED_SCHEMAS=public
QUERY_TIMEOUT=10
MAX_ROWS=1000
CSV_EXPORT_DIR=/tmp/db_exports

# LLM for SQL generation (required for generate_sql tool)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key
MODEL=gpt-4o
